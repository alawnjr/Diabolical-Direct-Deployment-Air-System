# 12 ALGORITHM ANGLE-ASSIGNMENT FUNCTIONS
# ─────────────────────────────────────────────────────────────────────────────

def assign_grid_sweep(drones, num_bait, num_recv):
    """Parallel lanes: bait drones spread evenly across full 0-90 arc."""
    baits = _bait(drones)
    for drone, angle in zip(baits, _spread_angles(len(baits), 0.0, math.pi/2)):
        drone.angle = angle

def assign_spiral_outward(drones, num_bait, num_recv):
    """Tight cluster near 45 then offset by small increments; good near known emitter."""
    baits = _bait(drones)
    n = len(baits)
    base = math.pi / 4
    spread = math.radians(20)
    for i, drone in enumerate(baits):
        offset = (i - n / 2) * (spread / max(n - 1, 1))
        drone.angle = base + offset

def assign_saturation_fan(drones, num_bait, num_recv):
    """Full 0-90 spread; recv clustered centrally. Cheap overload, attrition-heavy."""
    baits = _bait(drones)
    for drone, angle in zip(baits, _spread_angles(len(baits), 0.0, math.pi/2)):
        drone.angle = angle
    recvs = _recv(drones)
    for drone, angle in zip(recvs, _spread_angles(len(recvs), math.radians(30), math.radians(60))):
        drone.angle = angle

def assign_bait_ladder(drones, num_bait, num_recv):
    """Shallow-to-steep stagger: first drone enters threat zone early, triggers pings."""
    baits = _bait(drones)
    for drone, angle in zip(baits, _spread_angles(len(baits), math.radians(5), math.radians(85))):
        drone.angle = angle

def assign_reload_trap(drones, num_bait, num_recv):
    """Wave 1 drains SAM magazines (15-45); wave 2 exploits emptied launchers (45-85)."""
    baits = _bait(drones)
    n = len(baits)
    wave1 = baits[:n//2]
    wave2 = baits[n//2:]
    for drone, angle in zip(wave1, _spread_angles(len(wave1), math.radians(15), math.radians(45))):
        drone.angle = angle
    for drone, angle in zip(wave2, _spread_angles(len(wave2), math.radians(45), math.radians(85))):
        drone.angle = angle
    recvs = _recv(drones)
    for drone, angle in zip(recvs, _spread_angles(len(recvs), math.radians(40), math.radians(80))):
        drone.angle = angle

def assign_multi_azimuth(drones, num_bait, num_recv):
    """Four distinct axes (10,30,60,80 deg) to overload radar tracking."""
    axes = [math.radians(a) for a in [10, 30, 60, 80]]
    for i, drone in enumerate(_bait(drones)):
        drone.angle = axes[i % len(axes)]

def assign_random_walk(drones, num_bait, num_recv):
    """Random heading per drone. Hard to predict; inefficient. Chaos baseline."""
    for drone in _bait(drones):
        drone.angle = random.uniform(0, math.pi/2)

def assign_sector_claim(drones, num_bait, num_recv):
    """Interleaved bait+recv sectors; prevents angular overlap. Great scaling."""
    total = num_bait + num_recv
    all_angles = _spread_angles(total, math.radians(2), math.radians(88))
    baits = _bait(drones)
    recvs = _recv(drones)
    bait_angles = [all_angles[i] for i in range(0, total, 2)][:len(baits)]
    recv_angles  = [all_angles[i] for i in range(1, total, 2)][:len(recvs)]
    for drone, angle in zip(baits, bait_angles):
        drone.angle = angle
    for drone, angle in zip(recvs, recv_angles):
        drone.angle = angle

def assign_triangulation_lite(drones, num_bait, num_recv):
    """Pairs of drones fly 8-deg apart so both enter a radar ring simultaneously."""
    baits = _bait(drones)
    n = len(baits)
    pair_sep = math.radians(8)
    base_angles = _spread_angles((n+1)//2, math.radians(10), math.radians(80))
    for i, drone in enumerate(baits):
        base = base_angles[min(i//2, len(base_angles)-1)]
        drone.angle = base + (pair_sep/2 if i%2==0 else -pair_sep/2)

def assign_hotspot_reinforce(drones, num_bait, num_recv):
    """20% scouts spread wide; 80% mass at 45 ready to exploit any hotspot."""
    baits = _bait(drones)
    n = len(baits)
    n_scouts = max(1, round(n*0.20))
    for drone, angle in zip(baits[:n_scouts], _spread_angles(n_scouts, math.radians(5), math.radians(85))):
        drone.angle = angle
    main = baits[n_scouts:]
    for drone, angle in zip(main, _spread_angles(len(main), math.radians(35), math.radians(55))):
        drone.angle = angle

def assign_scout_fix_finish(drones, num_bait, num_recv):
    """Scouts 25% wide, fixers 35% narrow, finishers 40% concentrated. Recv take high angles."""
    baits = _bait(drones)
    n = len(baits)
    n_s = max(1, round(n*0.25))
    n_f = max(1, round(n*0.35))
    scouts, fixers, finishers = baits[:n_s], baits[n_s:n_s+n_f], baits[n_s+n_f:]
    for drone, angle in zip(scouts,    _spread_angles(len(scouts),         math.radians(2),  math.radians(88))): drone.angle = angle
    for drone, angle in zip(fixers,    _spread_angles(len(fixers),         math.radians(30), math.radians(60))): drone.angle = angle
    for drone, angle in zip(finishers, _spread_angles(max(len(finishers),1),math.radians(40),math.radians(50))): drone.angle = angle
    recvs = _recv(drones)
    for drone, angle in zip(recvs, _spread_angles(len(recvs), math.radians(55), math.radians(85))):
        drone.angle = angle

def assign_meta_selector(drones, num_bait, num_recv):
    """Combines fan (1st third), reload-trap wave2 (2nd third), finisher cluster (3rd third)."""
    baits = _bait(drones)
    n = len(baits)
    t = n // 3
    fan, trap, finish = baits[:t], baits[t:2*t], baits[2*t:]
    for drone, angle in zip(fan,    _spread_angles(len(fan),             math.radians(0),  math.radians(90))): drone.angle = angle
    for drone, angle in zip(trap,   _spread_angles(len(trap),            math.radians(45), math.radians(85))): drone.angle = angle
    for drone, angle in zip(finish, _spread_angles(max(len(finish),1),   math.radians(40), math.radians(50))): drone.angle = angle
    recvs = _recv(drones)
    pair_sep = math.radians(8)
    base_angles = _spread_angles((len(recvs)+1)//2, math.radians(15), math.radians(75))
    for i, drone in enumerate(recvs):
        base = base_angles[min(i//2, len(base_angles)-1)]
        drone.angle = base + (pair_sep/2 if i%2==0 else -pair_sep/2)


