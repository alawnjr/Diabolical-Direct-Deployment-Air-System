def run_sim_with_algo(algo: Algorithm, num_bait: int, num_recv: int) -> SimState:
    state = initialize_sim(num_bait, num_recv)
    algo.assign_fn(state.lucas_drones, num_bait, num_recv)
    run_to_completion(state)
    return state


@dataclass
class TrialResult:
    algo: Algorithm
    scores: list          = field(default_factory=list)
    radars_killed: list   = field(default_factory=list)
    launchers_killed: list= field(default_factory=list)
    gas_collected: list   = field(default_factory=list)
    survival: list        = field(default_factory=list)
    missiles_taken: list  = field(default_factory=list)

    @property
    def avg(self):            return mean(self.scores)         if self.scores else 0.0
    @property
    def sd(self):             return stdev(self.scores)        if len(self.scores)>1 else 0.0
    @property
    def best(self):           return max(self.scores)          if self.scores else 0
    @property
    def worst(self):          return min(self.scores)          if self.scores else 0
    @property
    def avg_radars(self):     return mean(self.radars_killed)   if self.radars_killed else 0.0
    @property
    def avg_launchers(self):  return mean(self.launchers_killed) if self.launchers_killed else 0.0
    @property
    def avg_gas(self):        return mean(self.gas_collected)   if self.gas_collected else 0.0
    @property
    def avg_survival(self):   return mean(self.survival)        if self.survival else 0.0
    @property
    def avg_msls(self):       return mean(self.missiles_taken)  if self.missiles_taken else 0.0


def run_trials(algo, num_bait, num_recv, trials, verbose=False):
    r = TrialResult(algo=algo)
    total = num_bait + num_recv
    for t in range(trials):
        state = run_sim_with_algo(algo, num_bait, num_recv)
        rk = sum(1 for x in state.radars            if x.destroyed)
        lk = sum(1 for x in state.missile_launchers if x.destroyed)
        gk = sum(1 for x in state.gas_targets        if x.destroyed)
        al = sum(1 for x in state.lucas_drones       if x.alive)
        ms = sum(1 for e in state.events if e.get("type") == "missile_fired")
        r.scores.append(state.score)
        r.radars_killed.append(rk)
        r.launchers_killed.append(lk)
        r.gas_collected.append(gk)
        r.survival.append(al / max(total, 1))
        r.missiles_taken.append(ms)
        if verbose:
            print(f"  [{t+1:3d}/{trials}] score={state.score:3d}  R={rk}/{DEFAULT_NUM_RADARS}  "
                  f"L={lk}/{DEFAULT_NUM_LAUNCHERS}  G={gk}/{DEFAULT_NUM_GAS}  "
                  f"alive={al}/{total}  msls={ms}")
    return r


def preview_run(algo, num_bait, num_recv, delay=0.08):
    state = initialize_sim(num_bait, num_recv)
    algo.assign_fn(state.lucas_drones, num_bait, num_recv)
    print(f"\n{'─'*65}")
    print(f"  PREVIEW: {algo.name}  ({num_bait}b + {num_recv}r drones)")
    print(f"  Mission: {algo.mission}  |  Behavior: {algo.behavior}")
    print(f"  Strength: {algo.strength}  |  Weakness: {algo.weakness}")
    print(f"{'─'*65}\n")
    while not state.complete:
        evs = advance_tick(state)
        alive = sum(1 for d in state.lucas_drones if d.alive)
        done = int((state.tick / MAX_TICKS) * 30)
        bar = "█"*done + "░"*(30-done)
        print(f"  T{state.tick:02d} [{bar}] score={state.score:3d}  alive={alive:3d}", end="")
        for ev in evs:
            t = ev.get("type","")
            if   t == "radar_ping":           print(f"  📡{ev['radar_id']}", end="")
            elif t == "missile_fired":
                hit = "✓" if ev.get("hit") else "✗"
                print(f"  🚀{hit}→{ev['target_drone_id']}", end="")
            elif t == "radar_destroyed":      print(f"  💥R:{ev['radar_id']}+{ev['score_gained']}", end="")
            elif t == "launcher_destroyed":   print(f"  💥L:{ev['launcher_id']}+{ev['score_gained']}", end="")
            elif t == "gas_target_destroyed": print(f"  ☠G:{ev['target_id']}+{ev['score_gained']}", end="")
        print()
        if delay > 0: time.sleep(delay)
    rk = sum(1 for r in state.radars            if r.destroyed)
    lk = sum(1 for l in state.missile_launchers if l.destroyed)
    gk = sum(1 for g in state.gas_targets        if g.destroyed)
    ms = sum(1 for e in state.events if e.get("type")=="missile_fired")
    print(f"\n  FINAL score={state.score}  R={rk}/{DEFAULT_NUM_RADARS}  "
          f"L={lk}/{DEFAULT_NUM_LAUNCHERS}  G={gk}/{DEFAULT_NUM_GAS}  msls_fired={ms}\n")


def print_results(results, num_bait, num_recv, trials):
    ranked = sorted(results, key=lambda r: r.avg, reverse=True)
    W = 138
    print(f"\n{'='*W}")
    print(f"  D3AS PATTERN LAB v2 — RESULTS")
    print(f"  Config: {num_bait}b + {num_recv}r drones  |  {trials} trials each")
    print(f"  Max possible: {MAX_POSSIBLE_SCORE}  "
          f"(R:{DEFAULT_NUM_RADARS}x{RADAR_VALUE}={DEFAULT_NUM_RADARS*RADAR_VALUE}  "
          f"L:{DEFAULT_NUM_LAUNCHERS}x{MISSILE_VALUE}={DEFAULT_NUM_LAUNCHERS*MISSILE_VALUE}  "
          f"G:{DEFAULT_NUM_GAS}x{GAS_VALUE}={DEFAULT_NUM_GAS*GAS_VALUE})  "
          f"|  SAMs: {SAM_MISSILES}/launcher  {MISSILE_HIT_RATE*100:.0f}% hit  "
          f"|  Radar on: 5/{30} ticks")
    print(f"{'='*W}")
    print(f"\n  {'#':<3} {'Algorithm':<22} {'Mission':<24} "
          f"{'Avg':>6} {'SD':>5} {'Best':>5} {'Worst':>5} "
          f"{'Radars':>8} {'Launchs':>8} {'Gas':>6} {'Surv':>6} "
          f"{'Msls':>5}  {'Pct':>5}  Bar")
    print(f"  {'─'*W}")
    for rank, r in enumerate(ranked, 1):
        pct = r.avg / MAX_POSSIBLE_SCORE * 100
        bar = "█"*int(pct/4) + "░"*(25-int(pct/4))
        tag = "  <- BEST" if rank==1 else ("  ^ TOP3" if rank<=3 else "")
        print(f"  {rank:<3} {r.algo.name:<22} {r.algo.mission:<24} "
              f"{r.avg:6.1f} {r.sd:5.1f} {r.best:5d} {r.worst:5d} "
              f"{r.avg_radars:5.1f}/{DEFAULT_NUM_RADARS} "
              f"{r.avg_launchers:5.1f}/{DEFAULT_NUM_LAUNCHERS} "
              f"{r.avg_gas:3.1f}/{DEFAULT_NUM_GAS} "
              f"{r.avg_survival*100:5.0f}% "
              f"{r.avg_msls:5.1f}  {pct:5.1f}%  {bar}{tag}")
    print(f"\n  {'─'*W}")
    print("  TOP 3 DOCTRINE NOTES:")
    for i, r in enumerate(ranked[:3]):
        a = r.algo
        print(f"  {'*' if i==0 else '-'} {a.name:<22}  str: {a.strength:<24}  "
              f"weak: {a.weakness:<26}  best vs: {a.best_against}")
    print(f"{'='*W}\n")


def main():
    p = argparse.ArgumentParser(description="D3AS Pattern Lab v2")
    p.add_argument("--bait",    type=int,   default=DEFAULT_BAIT)
    p.add_argument("--recv",    type=int,   default=DEFAULT_RECV)
    p.add_argument("--trials",  type=int,   default=50)
    p.add_argument("--algo",    type=int,   nargs="+")
    p.add_argument("--preview", type=int,   default=None)
    p.add_argument("--delay",   type=float, default=0.06)
    p.add_argument("--verbose", action="store_true")
    p.add_argument("--list",    action="store_true")
    args = p.parse_args()

    if args.list:
        print(f"\n  {'ID':<4} {'Algorithm':<22} {'Mission':<24} {'Logic':<34} {'Best Against'}")
        for a in ALGORITHMS:
            print(f"  {a.id:<4} {a.name:<22} {a.mission:<24} {a.logic:<34} {a.best_against}")
        return

    if args.preview is not None:
        match = [a for a in ALGORITHMS if a.id == args.preview]
        if not match: print(f"ID {args.preview} not found."); sys.exit(1)
        preview_run(match[0], args.bait, args.recv, delay=args.delay)
        return

    pool = ALGORITHMS if not args.algo else [a for a in ALGORITHMS if a.id in args.algo]
    if not pool: print("No matching IDs."); sys.exit(1)

    print(f"\n  D3AS v2  |  {args.bait}b+{args.recv}r  |  {args.trials} trials each")
    print(f"  Running {len(pool)} algorithm(s)...\n")

    results = []
    for a in pool:
        print(f"  [{a.id:2d}] {a.name:<22} ...", end="", flush=True)
        if args.verbose: print()
        t0 = time.time()
        r = run_trials(a, args.bait, args.recv, args.trials, args.verbose)
        results.append(r)
        print(f"  avg={r.avg:.1f}  best={r.best}  ({time.time()-t0:.1f}s)")

    print_results(results, args.bait, args.recv, args.trials)

if __name__ == "__main__":
    main()
