# ─────────────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────────────
def _spread_angles(n: int, angle_min: float, angle_max: float) -> list[float]:
    if n <= 0:
        return []
    if n == 1:
        return [(angle_min + angle_max) / 2]
    return [angle_min + i * (angle_max - angle_min) / (n - 1) for i in range(n)]

def _bait(drones):  return [d for d in drones if d.drone_type == "bait"]
def _recv(drones):  return [d for d in drones if d.drone_type == "radar_receiver"]


